# Template for infra/.env — copied by `make init`. Edit infra/.env, not this file.

# Postgres
POSTGRES_USER=neuroatlas
POSTGRES_PASSWORD=password
POSTGRES_DB=neuroatlas
POSTGRES_URI=postgresql+asyncpg://neuroatlas:password@localhost:5432/neuroatlas

# Kafka
# Local uvicorn: KAFKA_ENABLED=false (default) uses InMemEventBus.
# Docker ML consumer: set KAFKA_ENABLED=true, then run:
#   make up_infra && make kafka_topics && make up_ml
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_DOCKER_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=neuroatlas
KAFKA_CONSUMER_GROUP=neuroatlas
KAFKA_ENABLED=false

# Service runtime
# admin_ui=8000, patients=8001, ml=8002, housekeeper=8003 (housekeeper reuses POSTGRES_URI)
# Docker: make up_infra (Postgres + Kafka + Keycloak) then make up_app or make up_<abbr>
# ML + Kafka: set KAFKA_ENABLED=true, then make up_infra && make kafka_topics && make up_ml
LOG_LEVEL=INFO
ENVIRONMENT=local

# Authentication (Keycloak OIDC — see docs/diagrams/auth-keycloak-user-registration.md)
# Local dev: AUTH_ENABLED=false (NullAuthAdapter). With Keycloak: make up_infra, then AUTH_ENABLED=true.
AUTH_ENABLED=false
USER_UPSERT_ENABLED=true
OIDC_JWKS_URL=http://localhost:8080/realms/neuroatlas/protocol/openid-connect/certs
OIDC_ISSUER=http://localhost:8080/realms/neuroatlas
OIDC_AUDIENCE=neuroatlas-api
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Matches neuroatlas-api client secret from infra/keycloak/import/neuroatlas-realm.json
KEYCLOAK_CLIENT_SECRET=dev-neuroatlas-api-secret

# Admin UI BFF (browser entry — see docs/diagrams/edge-architecture.md)
# Public client neuroatlas-ui — no secret; configured in infra/keycloak/import/neuroatlas-realm.json
KEYCLOAK_URL=http://localhost:8080
# Browser-facing Keycloak URL for OIDC authorize redirects (defaults to KEYCLOAK_URL when unset).
# Docker compose overrides KEYCLOAK_URL to http://keycloak:8080 and sets KEYCLOAK_BROWSER_URL here.
KEYCLOAK_BROWSER_URL=
KEYCLOAK_REALM=neuroatlas
KEYCLOAK_UI_CLIENT_ID=neuroatlas-ui
KEYCLOAK_UI_CLIENT_SECRET=
PATIENTS_ROUTE=localhost:8001
ML_ROUTE=localhost:8002
HOUSEKEEPER_ROUTE=localhost:8003
NEUROATLAS_ACCESS_TOKEN=NEUROATLAS_ACCESS_TOKEN
NEUROATLAS_REFRESH_TOKEN=NEUROATLAS_REFRESH_TOKEN
NEUROATLAS_TOKEN_SIGN=NEUROATLAS_TOKEN_SIGN

# LLM provider (set at integration time; keep out of git)
OPENAI_API_KEY=
LLM_BASE_URL=

# Jira (Atlassian Cloud — see docs/jira/README.md)
JIRA_BASE_URL=https://neurojihad.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NLS

# E2E smoke (NLS-68 — see docs/smoke/admin-ui-e2e.md)
# SMOKE_INTEGRATION=1
# SMOKE_USERNAME=
# SMOKE_PASSWORD=
USERNAME=admin
PASSWORD=Admin123!
